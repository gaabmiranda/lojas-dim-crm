# ─── Banco ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://crm:crm@localhost:5432/crm

# ─── Auth.js v5 ───────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Em produção, AUTH_TRUST_HOST=true se atrás de proxy
AUTH_TRUST_HOST=true

# ─── Bling API v3 (OAuth) ─────────────────────────────────────────────────
# App ID 335719 — ver memory/reference_bling_app.md
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
# HMAC shared secret pro webhook receiver. Configurar mesmo valor na aba Webhooks do app.
BLING_WEBHOOK_SECRET=

# ─── Chatwoot ─────────────────────────────────────────────────────────────
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
# ID da inbox WhatsApp Baileys
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=

# ─── n8n ──────────────────────────────────────────────────────────────────
# Ex: https://n8n.lojasdim.com.br/webhook
N8N_WEBHOOK_BASE_URL=
N8N_SHARED_SECRET=

# ─── Anthropic (opcional — só usado se IA_AGENTS_ENABLED=true via feature flag) ──
ANTHROPIC_API_KEY=

# ─── Sistema ──────────────────────────────────────────────────────────────
TZ=America/Sao_Paulo
NODE_ENV=development

# ─── Bootstrap ────────────────────────────────────────────────────────────
# Diretório dos ndjson exportados do Bling (script scripts/bootstrap-bling.ts)
# Default: C:/Users/GabrielM Pc/Documents/
BOOTSTRAP_NDJSON_DIR=
