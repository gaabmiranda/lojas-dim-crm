{
  "name": "04 - Cron D+90 Reativação",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 10 * * *" }] }
      },
      "id": "schedule-1",
      "name": "Schedule 10h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.CRM_BASE_URL }}/api/cron/transitions",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-N8N-Secret", "value": "={{ $env.N8N_SHARED_SECRET }}" }]
        },
        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={\"tipo\":\"reativacao\"}",
        "options": {}
      },
      "id": "http-1",
      "name": "POST tipo=reativacao",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    }
  ],
  "connections": {
    "Schedule 10h": { "main": [[{ "node": "POST tipo=reativacao", "type": "main", "index": 0 }]] }
  }
}
